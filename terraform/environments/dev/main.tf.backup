terraform {
  required_providers {
    google = {
      source  = "hashicorp/google"
      version = "~> 6.0"
    }
  }
}

provider "google" {
  project = "project-a9c3b175-7f78-4ba6-9ad"
  region  = "europe-west2"
  zone    = "europe-west2-a"
}

resource "google_compute_instance" "vm1" {
  name         = "terraform-vm"
  machine_type = "e2-micro"
  
  labels = local.mandatory_labels

  boot_disk {
    initialize_params {
      image = "debian-cloud/debian-12"
    }
  }

  network_interface {
    network = "default"

    access_config {}
  }
}

resource "google_storage_bucket" "test" {
  name     = "test-bucket-partial-${random_id.suffix.hex}"
  location = "US"

  labels = {
    application = "demo"
  }
}

resource "random_id" "suffix" {
  byte_length = 4
}
