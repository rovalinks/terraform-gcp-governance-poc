# --------------------------------------------------
# HOW TO FIND PROJECT ID
# --------------------------------------------------
# gcloud config get-value project
#
# Example Output:
# project-a9c3b175-7f78-4ba6-9ad
#
# export PROJECT_ID="project-a9c3b175-7f78-4ba6-9ad"

# --------------------------------------------------
# HOW TO FIND ORGANIZATION ID
# --------------------------------------------------
# gcloud organizations list
#
# Example Output:
# DISPLAY_NAME     ID
# customer-org     321880981428
#
# export ORG_ID="321880981428"

project_id = "project-a9c3b175-7f78-4ba6-9ad"
org_id     = "321880981428"